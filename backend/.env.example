# =============================================================================
# .env.example — Environment variable template for the Agentic Cloud Assistant
#
# Copy this file to .env and fill in your real values:
#   cp .env.example .env
#
# .env is listed in .gitignore and must never be committed to source control.
# =============================================================================


# -----------------------------------------------------------------------------
# LLM API Keys
# At least one is required. The frontend lets you choose which model to use.
# -----------------------------------------------------------------------------

# Groq API key — used when model is set to "groq" in the frontend.
# Get a free key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Ollama base URL — used when model is set to "ollama" in the frontend.
# Leave blank to default to http://localhost:11434
# Local development (without Docker):
# OLLAMA_BASE_URL=http://localhost:11434
# Docker (Ollama running natively on the host):
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Anthropic API key — used when model is set to "anthropic" in the frontend.
# Get a key at https://console.anthropic.com
# Also required for the /agent/run endpoint (agentic loop uses claude-opus-4-5).
ANTHROPIC_API_KEY=your_anthropic_api_key_here


# -----------------------------------------------------------------------------
# AWS Configuration (server-side defaults)
# These are used as fallbacks when the frontend does not supply credentials.
# For production use, prefer IAM roles over hardcoded keys.
# -----------------------------------------------------------------------------

# Default AWS region for boto3 calls that do not receive an explicit region.
# The frontend can override this per-request via the Cloud Credentials tab.
AWS_DEFAULT_REGION=us-east-1

# AWS access key ID — leave blank if using IAM instance roles or aws configure.
# AWS_ACCESS_KEY_ID=your_aws_access_key_id_here

# AWS secret access key — leave blank if using IAM instance roles or aws configure.
# AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here


# -----------------------------------------------------------------------------
# Strategy 3 — Remote S3 State Backend (optional, recommended for production)
#
# When TF_STATE_BUCKET is set, every terraform init writes a backend.tf that
# stores state in S3 and uses DynamoDB for locking instead of a local tfstate
# file. This makes state durable, survives container restarts, and enables
# concurrent-safe applies.
#
# Leave TF_STATE_BUCKET blank to use local state (default / dev mode).
#
# One-time AWS setup:
#   aws s3api create-bucket --bucket <your-bucket> --region us-east-1
#   aws s3api put-bucket-versioning \
#       --bucket <your-bucket> \
#       --versioning-configuration Status=Enabled
#   aws s3api put-bucket-encryption \
#       --bucket <your-bucket> \
#       --server-side-encryption-configuration \
#       '{"Rules":[{"ApplyServerSideEncryptionByDefault":{"SSEAlgorithm":"AES256"}}]}'
#   aws dynamodb create-table \
#       --table-name terraform-state-lock \
#       --attribute-definitions AttributeName=LockID,AttributeType=S \
#       --key-schema AttributeName=LockID,KeyType=HASH \
#       --billing-mode PAY_PER_REQUEST \
#       --region us-east-1
# -----------------------------------------------------------------------------

# S3 bucket that holds terraform.tfstate for every execution.
# TF_STATE_BUCKET=my-app-tfstate

# DynamoDB table used for state locking (prevents concurrent applies).
# TF_STATE_LOCK_TABLE=terraform-state-lock

# Region where the S3 bucket and DynamoDB table live.
# TF_STATE_REGION=us-east-1


# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------

# Set to "true" to enable FastAPI debug mode (auto-reload, verbose errors).
# Set to "false" or remove this line in any internet-facing deployment.
DEBUG=true
